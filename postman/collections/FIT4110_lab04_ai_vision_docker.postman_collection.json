              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=400" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-20260519-missing-image\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"motionScore\": 0.87\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
