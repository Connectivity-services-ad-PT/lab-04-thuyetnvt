    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Camera Stream smoke - call AI Vision mock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{aiVisionMockUrl}}/vision/detect",
              "host": ["{{aiVisionMockUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-camera-smoke-0001\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"imageUrl\": \"https://storage.smart-campus.local/frames/cam-b2-001/smoke.jpg\",\n  \"motionScore\": 0.87,\n  \"priority\": \"high\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
