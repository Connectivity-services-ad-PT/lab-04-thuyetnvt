                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /vision/detect - duplicate correlationId conflict",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=409" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-20260519-0001\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"imageUrl\": \"https://storage.smart-campus.local/frames/cam-b2-001/different.jpg\",\n  \"motionScore\": 0.4\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Duplicate correlationId with different payload returns 409', function () { pm.response.to.have.status(409); });",
                  "pm.test('Conflict explains idempotency problem', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 409);",
                  "  pm.expect(json).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /vision/detections/{detectionId} - unknown detection returns 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Prefer", "value": "code=404" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detections/det-20260519-9999",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detections", "det-20260519-9999"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unknown detection returns 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('NotFound response follows Problem Details', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
