{
  "info": {
    "_postman_id": "fit4110-lab03-ai-vision",
    "name": "FIT4110 Lab04 - Dockerized AI Vision Contract Tests",
    "description": "Postman collection for Pair 01 Camera Stream -> AI Vision. Tests are based on the Lab 02/Lab 03 contract and run against Prism mock or the Dockerized AI Vision service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab03-ai-vision';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - AI Vision is alive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Health response identifies AI Vision', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "  pm.expect(json).to.have.property('service', 'ai-vision');",
                  "  pm.expect(json).to.have.property('time');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /vision/detect - completed detection happy path",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-20260519-0001\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"imageUrl\": \"https://storage.smart-campus.local/frames/cam-b2-001/20260519T033000Z.jpg\",\n  \"motionScore\": 0.87,\n  \"priority\": \"high\",\n  \"location\": {\n    \"building\": \"B\",\n    \"floor\": \"04\",\n    \"zone\": \"north-gate\"\n  },\n  \"metadata\": {\n    \"frameWidth\": 1920,\n    \"frameHeight\": 1080\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Detection response has required fields', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('detectionId');",
                  "  pm.expect(json).to.have.property('correlationId');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(['queued', 'processing', 'completed', 'failed']).to.include(json.status);",
                  "  pm.expect(json).to.have.property('riskLevel');",
                  "  pm.expect(['low', 'medium', 'high', 'critical']).to.include(json.riskLevel);",
                  "  pm.expect(json.confidence).to.be.within(0, 1);",
                  "  pm.expect(json.objects).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /vision/detections/{detectionId} - polling result",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vision/detections/det-20260519-0001",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detections", "det-20260519-0001"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Polling returns a detection result', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('detectionId');",
                  "  pm.expect(json.detectionId).to.match(/^det-[0-9]{8}-[0-9]{4}$/);",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /vision/models/info - model readiness",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vision/models/info",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "models", "info"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Model info exposes readiness state', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('modelId');",
                  "  pm.expect(json).to.have.property('version');",
                  "  pm.expect(['ready', 'warming_up', 'unavailable']).to.include(json.status);",
                  "  pm.expect(json.supportedObjectTypes).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /vision/models/info - valid token is accepted",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vision/models/info",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "models", "info"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Valid token request returns success', function () { pm.expect(pm.response.code).to.eql(200); });"]
              }
            }
          ]
        },
        {
          "name": "POST /vision/detect - missing token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-20260519-auth-missing\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"imageUrl\": \"https://storage.smart-campus.local/frames/cam-b2-001/auth.jpg\",\n  \"motionScore\": 0.7\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce bearer auth', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /vision/detect - invalid token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid-token" }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detect",
              "host": ["{{baseUrl}}"],
              "path": ["vision", "detect"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cameraId\": \"CAM-B2-001\",\n  \"correlationId\": \"corr-20260519-auth-invalid\",\n  \"capturedAt\": \"2026-05-19T03:30:00Z\",\n  \"imageUrl\": \"https://storage.smart-campus.local/frames/cam-b2-001/auth-invalid.jpg\",\n  \"motionScore\": 0.7\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token requires real auth middleware', function () { pm.expect(true).to.eql(true); });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 or 403', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
